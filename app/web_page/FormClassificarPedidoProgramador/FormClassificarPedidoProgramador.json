  "variables" : {
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.pedido ){",
        "\treturn {",
        "\t\t//map pedido variable to expected task contract input",
        "\t\tpedidoInput: {",
        "\t\t\ttitulo: $data.pedido.titulo !== undefined ? $data.pedido.titulo : null,",
        "\t\t\tdescricao: $data.pedido.descricao !== undefined ? $data.pedido.descricao : null,",
        "\t\t\ttipo: $data.pedido.tipo !== undefined ? $data.pedido.tipo : null,",
        "\t\t\testimativaDias: $data.pedido.estimativaDias !== undefined ? $data.pedido.estimativaDias : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "pedido" : {
      "type" : "url",
      "value" : [
        "../{{context.pedido_ref.link}}"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    },
    "tipoOpcoes" : {
      "type" : "json",
      "value" : [
        "[\"MELHORIA\", \"ALTERACAO_FUNCIONAL\", \"PROJETO\"]"
      ],
